local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local CoreGui = game:GetService("CoreGui")

local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera
local Mouse = LocalPlayer:GetMouse()

local MasterUnload = {Modules = {}, Connections = {}, Instances = {}}

function MasterUnload:RegisterModule(Module) table.insert(self.Modules, Module) end
function MasterUnload:RegisterConnection(Connection) table.insert(self.Connections, Connection) end
function MasterUnload:RegisterInstance(Instance) table.insert(self.Instances, Instance) end

function MasterUnload:UnloadAll()
    for _, Module in pairs(self.Modules) do pcall(function() if Module.Unload then Module:Unload() end end) end
    for _, Connection in pairs(self.Connections) do pcall(function() Connection:Disconnect() end) end
    for _, Instance in pairs(self.Instances) do pcall(function() if Instance and Instance.Parent then Instance:Destroy() end end) end
    if LocalPlayer.Character then
        local Humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if Humanoid then Humanoid.WalkSpeed = 16; Humanoid.JumpPower = 50 end
    end
    for _, Gui in pairs(CoreGui:GetChildren()) do if Gui.Name:find("phase") then pcall(function() Gui:Destroy() end) end end
    local MT = getrawmetatable(Mouse)
    if MT and MT.__index then setreadonly(MT, false); MT.__index = nil; setreadonly(MT, true) end
end

local function IsAlive(Player)
    if not Player or not Player.Character then return false end
    local Humanoid = Player.Character:FindFirstChildOfClass("Humanoid")
    if not Humanoid or Humanoid.Health <= 0 then return false end
    if shared.phase.Checks.Knocked then
        local BodyEffects = Player.Character:FindFirstChild("BodyEffects")
        if BodyEffects then
            if BodyEffects:FindFirstChild("K.O") and BodyEffects["K.O"].Value then return false end
            if BodyEffects:FindFirstChild("Knocked") and BodyEffects.Knocked.Value then return false end
        end
    end
    if shared.phase.Checks.Forcefield then if Player.Character:FindFirstChildOfClass("ForceField") then return false end end
    return true
end

local function GetClosestPlayer()
    if not shared.phase['Silent Aim'].Enabled and not shared.phase['Trigger Bot'].Enabled and not shared.phase['Camera Lock'].Enabled then return nil end
    local Closest, Best = nil, shared.phase['Silent Aim'].FOV.Radius
    local MousePos = UserInputService:GetMouseLocation()
    for _, Player in pairs(Players:GetPlayers()) do
        if Player ~= LocalPlayer and IsAlive(Player) then
            local Head = Player.Character:FindFirstChild("Head")
            if Head then
                local Pos, On = Camera:WorldToViewportPoint(Head.Position)
                if On then
                    local Dist = (Vector2.new(Pos.X, Pos.Y) - MousePos).Magnitude
                    if Dist < Best then Best = Dist; Closest = Player end
                end
            end
        end
    end
    return Closest
end

local Target = nil

local HUD = {Enabled = shared.phase.Miscelaneous['Key Display'].Enabled, UIObjects = {}}

function HUD:Create()
    if not self.Enabled then return end
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "phase_hud"
    ScreenGui.Parent = CoreGui
    MasterUnload:RegisterInstance(ScreenGui)

    local TitleLabel = Instance.new("TextLabel")
    TitleLabel.Size = UDim2.new(1, 0, 0, 24)
    TitleLabel.Position = UDim2.new(0.5, 0, 0.5, 366)
    TitleLabel.AnchorPoint = Vector2.new(0.5, 0.5)
    TitleLabel.BackgroundTransparency = 1
    TitleLabel.Text = shared.phase.Miscelaneous['Key Display'].Title
    TitleLabel.TextColor3 = shared.phase.Miscelaneous['Key Display']['Key Color']
    TitleLabel.TextSize = 18.2
    TitleLabel.Font = Enum.Font.GothamBold
    TitleLabel.ZIndex = 10
    TitleLabel.Parent = ScreenGui
    Instance.new("UIStroke", TitleLabel).Thickness = 0.8

    local FeaturesLabel = Instance.new("TextLabel")
    FeaturesLabel.Size = UDim2.new(1, 0, 0, 24)
    FeaturesLabel.Position = UDim2.new(0.5, 0, 0.5, 385)
    FeaturesLabel.AnchorPoint = Vector2.new(0.5, 0.5)
    FeaturesLabel.BackgroundTransparency = 1
    FeaturesLabel.Text = ""
    FeaturesLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    FeaturesLabel.TextSize = 13
    FeaturesLabel.Font = Enum.Font.GothamBold
    FeaturesLabel.ZIndex = 10
    FeaturesLabel.Parent = ScreenGui
    Instance.new("UIStroke", FeaturesLabel).Thickness = 0.8

    local TargetLabel = Instance.new("TextLabel")
    TargetLabel.Size = UDim2.new(1, 0, 0, 20)
    TargetLabel.Position = UDim2.new(0.5, 0, 0.5, 400)
    TargetLabel.AnchorPoint = Vector2.new(0.5, 0.5)
    TargetLabel.BackgroundTransparency = 1
    TargetLabel.Text = ""
    TargetLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    TargetLabel.TextSize = 13.5
    TargetLabel.Font = Enum.Font.GothamBold
    TargetLabel.ZIndex = 10
    TargetLabel.Parent = ScreenGui
    Instance.new("UIStroke", TargetLabel).Thickness = 0.8

    self.UIObjects = {FeaturesLabel = FeaturesLabel, TargetLabel = TargetLabel}
    self:UpdateFeatures()
end

function HUD:UpdateFeatures()
    if not self.Enabled or not self.UIObjects.FeaturesLabel then return end
    local Active = {}
    if shared.phase['Silent Aim'].Enabled then table.insert(Active, "Silent") end
    if shared.phase['Trigger Bot'].Enabled then table.insert(Active, "Trigger") end
    if shared.phase.ESP.Enabled then table.insert(Active, "ESP") end
    if shared.phase['Local Player'].Speed.Enabled then table.insert(Active, "Speed") end
    if shared.phase['Camera Lock'].Enabled then table.insert(Active, "Cam") end
    if shared.phase['Hitbox Expander'].Enabled then table.insert(Active, "Hitbox") end
    if shared.phase['Infinite Range'].Enabled then table.insert(Active, "InfRange") end
    if shared.phase['Gun Modifications']['Instant Fire'].Enabled then table.insert(Active, "Rapid") end
    local Text = table.concat(Active, " | ")
    if Text == "" then Text = "phase.cc" end
    self.UIObjects.FeaturesLabel.Text = Text
end

function HUD:SetTarget(Name, Active)
    if not self.Enabled or not self.UIObjects.TargetLabel then return end
    if Name and Active then
        self.UIObjects.TargetLabel.Text = Name
        self.UIObjects.TargetLabel.TextColor3 = shared.phase.Miscelaneous['Key Display']['Key Color']
    elseif Name and not Active then
        self.UIObjects.TargetLabel.Text = Name
        self.UIObjects.TargetLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    else
        self.UIObjects.TargetLabel.Text = ""
    end
end

function HUD:Start()
    self:Create()
    MasterUnload:RegisterModule(self)
end

function HUD:Unload() self.Enabled = false end

local ESP = {Enabled = shared.phase.ESP.Enabled, ESPCache = {}, Connections = {}}

function ESP:CreateESP(Player)
    if not self.Enabled then return end
    local HRP = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if not HRP then return end
    if self.ESPCache[Player] then pcall(function() self.ESPCache[Player]:Destroy() end) end

    local Billboard = Instance.new("BillboardGui")
    Billboard.Size = UDim2.new(0, 100, 0, 30)
    Billboard.StudsOffset = Vector3.new(0, -3, 0)
    Billboard.AlwaysOnTop = true
    Billboard.MaxDistance = 500
    Billboard.Parent = HRP
    MasterUnload:RegisterInstance(Billboard)

    local Display = Instance.new("TextLabel")
    Display.Size = UDim2.new(1, 0, 0.5, 0)
    Display.BackgroundTransparency = 1
    Display.Text = Player.DisplayName
    Display.TextColor3 = (Player == Target) and shared.phase.ESP.Names['Target Color'] or shared.phase.ESP.Names.Color
    Display.TextSize = 12
    Display.Font = Enum.Font.GothamBold
    Display.TextStrokeTransparency = 0.5
    Display.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    Display.Parent = Billboard

    local Username = Instance.new("TextLabel")
    Username.Size = UDim2.new(1, 0, 0.5, 0)
    Username.Position = UDim2.new(0, 0, 0.5, -2)
    Username.BackgroundTransparency = 1
    Username.Text = "@" .. Player.Name
    Username.TextColor3 = (Player == Target) and shared.phase.ESP.Names['Target Color'] or shared.phase.ESP.Names.Color
    Username.TextSize = 10
    Username.Font = Enum.Font.GothamBold
    Username.TextStrokeTransparency = 0.6
    Username.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    Username.TextTransparency = 0.3
    Username.Parent = Billboard

    self.ESPCache[Player] = Billboard
end

function ESP:Refresh()
    if not self.Enabled then return end
    for Player, Billboard in pairs(self.ESPCache) do
        if not Player or not Player.Parent or not IsAlive(Player) then
            pcall(function() Billboard:Destroy() end)
            self.ESPCache[Player] = nil
        end
    end
    for _, Player in pairs(Players:GetPlayers()) do
        if Player ~= LocalPlayer and IsAlive(Player) then
            if not self.ESPCache[Player] then self:CreateESP(Player) end
            local Billboard = self.ESPCache[Player]
            if Billboard then
                for _, Label in pairs(Billboard:GetChildren()) do
                    if Label:IsA("TextLabel") then
                        Label.TextColor3 = (Player == Target) and shared.phase.ESP.Names['Target Color'] or shared.phase.ESP.Names.Color
                    end
                end
            end
        end
    end
    if Target and not IsAlive(Target) then Target = nil; HUD:SetTarget(nil, false) end
end

function ESP:Start()
    if not self.Enabled then return end
    for _, Player in pairs(Players:GetPlayers()) do
        if Player ~= LocalPlayer then
            Player.CharacterAdded:Connect(function(Char)
                Char:WaitForChild("HumanoidRootPart", 10)
                task.wait(0.5)
                if IsAlive(Player) then self:CreateESP(Player) end
            end)
        end
    end
    Players.PlayerAdded:Connect(function(Player)
        if Player ~= LocalPlayer then
            Player.CharacterAdded:Connect(function(Char)
                Char:WaitForChild("HumanoidRootPart", 10)
                task.wait(0.5)
                if IsAlive(Player) then self:CreateESP(Player) end
            end)
        end
    end)
    local Conn = RunService.RenderStepped:Connect(function() self:Refresh() end)
    table.insert(self.Connections, Conn)
    MasterUnload:RegisterConnection(Conn)
    MasterUnload:RegisterModule(self)
end

function ESP:Unload()
    self.Enabled = false
    for _, Billboard in pairs(self.ESPCache) do pcall(function() Billboard:Destroy() end) end
    self.ESPCache = {}
end

local SilentAim = {Enabled = shared.phase['Silent Aim'].Enabled}
function SilentAim:Setup()
    if not self.Enabled then return end
    local MT = getrawmetatable(Mouse)
    local Old = MT.__index
    setreadonly(MT, false)
    MT.__index = function(Self, Key)
        if Key == "Hit" and shared.phase['Silent Aim'].Enabled and Target and IsAlive(Target) then
            local Head = Target.Character:FindFirstChild("Head")
            if Head then return Head.CFrame end
        end
        return Old(Self, Key)
    end
    setreadonly(MT, true)
end
function SilentAim:Start() self:Setup() end

local TriggerBot = {Enabled = shared.phase['Trigger Bot'].Enabled, LastFire = 0}
function TriggerBot:Update()
    if not self.Enabled then return end
    if not Target or not IsAlive(Target) then return end
    local Now = tick()
    if Now - self.LastFire < shared.phase['Trigger Bot'].Delay then return end
    local Tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
    if Tool then Tool:Activate(); self.LastFire = Now end
end
function TriggerBot:Start()
    if not self.Enabled then return end
    local Conn = RunService.RenderStepped:Connect(function() self:Update() end)
    MasterUnload:RegisterConnection(Conn)
end

local Speed = {Enabled = shared.phase['Local Player'].Speed.Enabled}
function Speed:Update()
    if not self.Enabled then return end
    local Char = LocalPlayer.Character
    if Char then
        local Hum = Char:FindFirstChildOfClass("Humanoid")
        if Hum then Hum.WalkSpeed = 16 * shared.phase['Local Player'].Speed.Multiplier end
    end
end
function Speed:Start()
    if not self.Enabled then return end
    local Conn = RunService.RenderStepped:Connect(function() self:Update() end)
    MasterUnload:RegisterConnection(Conn)
end
function Speed:Unload()
    self.Enabled = false
    local Char = LocalPlayer.Character
    if Char then local Hum = Char:FindFirstChildOfClass("Humanoid"); if Hum then Hum.WalkSpeed = 16 end end
end

local CamLock = {Enabled = shared.phase['Camera Lock'].Enabled}
function CamLock:Update()
    if not self.Enabled then return end
    if not Target or not IsAlive(Target) then return end
    local Head = Target.Character:FindFirstChild("Head")
    if not Head then return end
    local Pos = Head.Position
    local HRP = Target.Character:FindFirstChild("HumanoidRootPart")
    if HRP then Pos = Pos + HRP.Velocity * shared.phase['Camera Lock'].Prediction end
    local TargetCF = CFrame.new(Camera.CFrame.Position, Pos)
    Camera.CFrame = Camera.CFrame:Lerp(TargetCF, shared.phase['Camera Lock'].Smoothing)
end
function CamLock:Start()
    if not self.Enabled then return end
    local Conn = RunService.RenderStepped:Connect(function() self:Update() end)
    MasterUnload:RegisterConnection(Conn)
end

local Jump = {Enabled = shared.phase['Local Player'].Jump.Enabled}
function Jump:Update()
    if not self.Enabled then return end
    local Char = LocalPlayer.Character
    if Char then
        local Hum = Char:FindFirstChildOfClass("Humanoid")
        if Hum then Hum.JumpPower = 50 * shared.phase['Local Player'].Jump.Multiplier end
    end
end
function Jump:Start()
    if not self.Enabled then return end
    local Conn = RunService.RenderStepped:Connect(function() self:Update() end)
    MasterUnload:RegisterConnection(Conn)
end
function Jump:Unload()
    self.Enabled = false
    local Char = LocalPlayer.Character
    if Char then local Hum = Char:FindFirstChildOfClass("Humanoid"); if Hum then Hum.JumpPower = 50 end end
end

local WallJump = {Enabled = shared.phase['Local Player'].WallJump.Enabled, HasWallJumped = false}
function WallJump:IsTouchingWall()
    local Char = LocalPlayer.Character
    if not Char then return false end
    local HRP = Char:FindFirstChild("HumanoidRootPart")
    if not HRP then return false end
    local RayParams = RaycastParams.new()
    RayParams.FilterDescendantsInstances = {Char}
    RayParams.FilterType = Enum.RaycastFilterType.Exclude
    local Dirs = {HRP.CFrame.LookVector * 3, -HRP.CFrame.LookVector * 3, HRP.CFrame.RightVector * 3, -HRP.CFrame.RightVector * 3}
    for _, Dir in pairs(Dirs) do if Workspace:Raycast(HRP.Position, Dir, RayParams) then return true end end
    return false
end
function WallJump:Perform()
    if not self.Enabled then return end
    local Char = LocalPlayer.Character
    if not Char then return end
    local Hum = Char:FindFirstChildOfClass("Humanoid")
    local HRP = Char:FindFirstChild("HumanoidRootPart")
    if not Hum or not HRP then return end
    local State = Hum:GetState()
    if State == Enum.HumanoidStateType.Freefall or State == Enum.HumanoidStateType.Jumping then
        if self:IsTouchingWall() and not self.HasWallJumped then
            self.HasWallJumped = true
            Hum.Jump = true
            HRP.Velocity = Vector3.new(HRP.Velocity.X, 50 * shared.phase['Local Player'].WallJump.Multiplier, HRP.Velocity.Z)
        end
    end
end
function WallJump:Start()
    if not self.Enabled then return end
    local Conn = LocalPlayer.CharacterAdded:Connect(function(Char)
        self.HasWallJumped = false
        local Hum = Char:WaitForChild("Humanoid")
        Hum.StateChanged:Connect(function(_, New) if New == Enum.HumanoidStateType.Landed then self.HasWallJumped = false end end)
    end)
    MasterUnload:RegisterConnection(Conn)
    if LocalPlayer.Character then
        local Hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if Hum then Hum.StateChanged:Connect(function(_, New) if New == Enum.HumanoidStateType.Landed then self.HasWallJumped = false end end) end
    end
end

local AntiFling = {Enabled = shared.phase['Local Player'].AntiFling.Enabled}
function AntiFling:Update()
    if not self.Enabled then return end
    local Char = LocalPlayer.Character
    if not Char then return end
    local HRP = Char:FindFirstChild("HumanoidRootPart")
    if not HRP then return end
    local Vel = HRP.Velocity
    if Vel.Y > 50 or Vel.Y < -50 then HRP.Velocity = Vector3.new(Vel.X, 0, Vel.Z) end
end
function AntiFling:Start()
    if not self.Enabled then return end
    local Conn = RunService.RenderStepped:Connect(function() self:Update() end)
    MasterUnload:RegisterConnection(Conn)
end

local HitboxExpander = {Enabled = shared.phase['Hitbox Expander'].Enabled, OriginalSizes = {}}
function HitboxExpander:Update()
    if not self.Enabled then return end
    for _, Player in pairs(Players:GetPlayers()) do
        if Player ~= LocalPlayer and IsAlive(Player) then
            local HRP = Player.Character:FindFirstChild("HumanoidRootPart")
            if HRP then
                if not self.OriginalSizes[Player] then self.OriginalSizes[Player] = HRP.Size end
                HRP.Size = Vector3.new(shared.phase['Hitbox Expander'].Size, shared.phase['Hitbox Expander'].Size, shared.phase['Hitbox Expander'].Size)
                HRP.Transparency = 0.7
                HRP.BrickColor = BrickColor.new("Bright red")
                HRP.Material = "Neon"
                HRP.CanCollide = false
            end
        end
    end
end
function HitboxExpander:Start()
    if not self.Enabled then return end
    local Conn = RunService.RenderStepped:Connect(function() self:Update() end)
    MasterUnload:RegisterConnection(Conn)
end
function HitboxExpander:Unload()
    self.Enabled = false
    for Player, Size in pairs(self.OriginalSizes) do
        if Player and Player.Character then
            local HRP = Player.Character:FindFirstChild("HumanoidRootPart")
            if HRP then HRP.Size = Size; HRP.Transparency = 1 end
        end
    end
    self.OriginalSizes = {}
end

local PanicGround = {Enabled = shared.phase['Local Player'].PanicGround.Enabled}
function PanicGround:Activate()
    if not self.Enabled then return end
    local Char = LocalPlayer.Character
    if not Char then return end
    local HRP = Char:FindFirstChild("HumanoidRootPart")
    if not HRP then return end
    local RayParams = RaycastParams.new()
    RayParams.FilterDescendantsInstances = {Char}
    RayParams.FilterType = Enum.RaycastFilterType.Exclude
    local RayResult = Workspace:Raycast(HRP.Position, Vector3.new(0, -500, 0), RayParams)
    if RayResult then HRP.CFrame = CFrame.new(RayResult.Position + Vector3.new(0, 3, 0)) end
end

local InstantFire = {Enabled = shared.phase['Gun Modifications']['Instant Fire'].Enabled, Connections = {}, OriginalValues = {}, IsHolding = false, HasFired = false}
function InstantFire:PatchTool(Tool)
    if not Tool or not Tool:IsA("Tool") then return end
    if self.OriginalValues[Tool] then return end
    local Cooldown = Tool:FindFirstChild("Shooting Cooldown")
    if Cooldown then self.OriginalValues[Tool] = Cooldown.Value; Cooldown.Value = 0 end
end
function InstantFire:UnpatchTools()
    for Tool, OriginalValue in pairs(self.OriginalValues) do
        if Tool and Tool.Parent then
            local Cooldown = Tool:FindFirstChild("Shooting Cooldown")
            if Cooldown then Cooldown.Value = OriginalValue end
        end
    end
    self.OriginalValues = {}
end
function InstantFire:FireBurst(Tool)
    for i = 1, shared.phase['Gun Modifications']['Instant Fire'].BurstCount do Tool:Activate() end
end
function InstantFire:Update()
    if not self.Enabled then return end
    local Char = LocalPlayer.Character
    if Char then
        local Tool = Char:FindFirstChildOfClass("Tool")
        if Tool then
            self:PatchTool(Tool)
            if self.IsHolding and not self.HasFired then self:FireBurst(Tool); self.HasFired = true end
        end
    end
end
function InstantFire:Start()
    if not self.Enabled then return end
    local Conn = RunService.RenderStepped:Connect(function() self:Update() end)
    table.insert(self.Connections, Conn)
    MasterUnload:RegisterConnection(Conn)
end
function InstantFire:Unload()
    self.Enabled = false
    self:UnpatchTools()
end

local ForceHit = {Enabled = shared.phase['Gun Modifications']['Force Hit'].Enabled}
function ForceHit:Setup()
    if not self.Enabled then return end
    local MT = getrawmetatable(Mouse)
    local Old = MT.__index
    setreadonly(MT, false)
    MT.__index = function(Self, Key)
        if Key == "Hit" and shared.phase['Gun Modifications']['Force Hit'].Enabled and Target and IsAlive(Target) then
            local Head = Target.Character:FindFirstChild("Head")
            if Head then return Head.CFrame end
        end
        return Old(Self, Key)
    end
    setreadonly(MT, true)
end
function ForceHit:Start() self:Setup() end

local InfRange = {Enabled = shared.phase['Infinite Range'].Enabled, OriginalValues = {}}
function InfRange:ModifyWeapon(Tool)
    if not Tool or not Tool:IsA("Tool") then return end
    if not self.OriginalValues[Tool] then self.OriginalValues[Tool] = {} end
    local Range = Tool:FindFirstChild("Range")
    if Range and typeof(Range.Value) == "number" then
        if not self.OriginalValues[Tool].Range then self.OriginalValues[Tool].Range = Range.Value end
        Range.Value = 1000
    end
end
function InfRange:Update()
    if not self.Enabled then return end
    local Char = LocalPlayer.Character
    if Char then local Tool = Char:FindFirstChildOfClass("Tool"); if Tool then self:ModifyWeapon(Tool) end end
end
function InfRange:Start()
    if not self.Enabled then return end
    local Conn = RunService.RenderStepped:Connect(function() self:Update() end)
    MasterUnload:RegisterConnection(Conn)
end

HUD:Start()
ESP:Start()
SilentAim:Start()
TriggerBot:Start()
Speed:Start()
CamLock:Start()
Jump:Start()
WallJump:Start()
AntiFling:Start()
HitboxExpander:Start()
InstantFire:Start()
ForceHit:Start()
InfRange:Start()

MasterUnload:RegisterModule(Speed)
MasterUnload:RegisterModule(Jump)
MasterUnload:RegisterModule(HitboxExpander)
MasterUnload:RegisterModule(InstantFire)

local Keybinds = shared.phase.Miscelaneous.Keybinds

UserInputService.InputBegan:Connect(function(Input, GameProcessed)
    if GameProcessed then return end

    if Input.KeyCode == Enum.KeyCode[Keybinds.Target] then
        Target = GetClosestPlayer()
        if Target then HUD:SetTarget(Target.Name, true) end
        ESP:Refresh()
    end

    if Input.KeyCode == Enum.KeyCode[Keybinds['Clear Target']] then
        Target = nil; HUD:SetTarget(nil, false); ESP:Refresh()
    end

    if Input.KeyCode == Enum.KeyCode[Keybinds['Trigger Bot']] then
        shared.phase['Trigger Bot'].Enabled = not shared.phase['Trigger Bot'].Enabled
        TriggerBot.Enabled = shared.phase['Trigger Bot'].Enabled
        HUD:UpdateFeatures()
    end

    if Input.KeyCode == Enum.KeyCode[Keybinds.Speed] then
        shared.phase['Local Player'].Speed.Enabled = not shared.phase['Local Player'].Speed.Enabled
        Speed.Enabled = shared.phase['Local Player'].Speed.Enabled
        HUD:UpdateFeatures()
        if not Speed.Enabled then Speed:Unload() end
    end

    if Input.KeyCode == Enum.KeyCode[Keybinds['Cam Lock']] then
        shared.phase['Camera Lock'].Enabled = not shared.phase['Camera Lock'].Enabled
        CamLock.Enabled = shared.phase['Camera Lock'].Enabled
        HUD:UpdateFeatures()
    end

    if Input.KeyCode == Enum.KeyCode[Keybinds.Jump] then
        shared.phase['Local Player'].Jump.Enabled = not shared.phase['Local Player'].Jump.Enabled
        Jump.Enabled = shared.phase['Local Player'].Jump.Enabled
        if not Jump.Enabled then Jump:Unload() end
    end

    if Input.KeyCode == Enum.KeyCode[Keybinds['Wall Jump']] then
        shared.phase['Local Player'].WallJump.Enabled = not shared.phase['Local Player'].WallJump.Enabled
        WallJump.Enabled = shared.phase['Local Player'].WallJump.Enabled
    end

    if Input.KeyCode == Enum.KeyCode[Keybinds['Force Hit']] then
        shared.phase['Gun Modifications']['Force Hit'].Enabled = not shared.phase['Gun Modifications']['Force Hit'].Enabled
        ForceHit.Enabled = shared.phase['Gun Modifications']['Force Hit'].Enabled
    end

    if Input.KeyCode == Enum.KeyCode[Keybinds['Hitbox Expander']] then
        shared.phase['Hitbox Expander'].Enabled = not shared.phase['Hitbox Expander'].Enabled
        HitboxExpander.Enabled = shared.phase['Hitbox Expander'].Enabled
        HUD:UpdateFeatures()
        if not HitboxExpander.Enabled then HitboxExpander:Unload() end
    end

    if Input.KeyCode == Enum.KeyCode[Keybinds['Panic Ground']] then PanicGround:Activate() end

    if Input.KeyCode == Enum.KeyCode[Keybinds['Instant Fire']] then
        shared.phase['Gun Modifications']['Instant Fire'].Enabled = not shared.phase['Gun Modifications']['Instant Fire'].Enabled
        InstantFire.Enabled = shared.phase['Gun Modifications']['Instant Fire'].Enabled
        HUD:UpdateFeatures()
        if not InstantFire.Enabled then InstantFire:Unload() end
    end

    if Input.KeyCode == Enum.KeyCode.Space then WallJump:Perform() end

    if Input.UserInputType == Enum.UserInputType.MouseButton1 then
        InstantFire.IsHolding = true; InstantFire.HasFired = false
    end

    if Input.KeyCode == Enum.KeyCode.End then MasterUnload:UnloadAll() end
end)

UserInputService.InputEnded:Connect(function(Input)
    if Input.UserInputType == Enum.UserInputType.MouseButton1 then InstantFire.IsHolding = false end
end)
